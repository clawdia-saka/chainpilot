{
  "name": "chainpilot",
  "version": "0.1.0",
  "description": "AI agent: cross-chain narrative allocator powered by LI.FI",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
